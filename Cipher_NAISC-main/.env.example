# ──────────────────────────────────────────────────────────
# Cipher_NAISC – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── Groq API (free tier at https://console.groq.com) ──────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Telegram Bot (create via @BotFather on Telegram) ──────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Detection thresholds ──────────────────────────────────
DANGER_WEAPON_THRESHOLD=0.50
DANGER_EMOTION_THRESHOLD=0.65
WEAPON_CONFIRMATION_FRAMES=3

# ── Model paths (optional overrides) ─────────────────────
# Leave blank to use the bundled model from perception-layer/
WEAPON_MODEL_PATH=
UNIFORM_MODEL_PATH=

# ── Video source ──────────────────────────────────────────
# 0        = live webcam (user must click "Activate" in dashboard)
# file path = demo mode: video loops automatically, no user gate
#   e.g. VIDEO_SOURCE=C:\Videos\demo.mp4
VIDEO_SOURCE=0
SAMPLE_FPS=2.0

# ── Groq Vision (webcam mode only) ────────────────────────
# Called when YOLOv8 confidence is in the uncertain zone (0.15–0.50)
# Rate-limited to 1 call per GROQ_VISION_MIN_INTERVAL seconds
GROQ_VISION_ENABLED=true
GROQ_VISION_MIN_INTERVAL=10

# ── API server ────────────────────────────────────────────
API_PORT=8000

# ── Frontend ─────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5173

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Multi-agent swarm (Phase 2) ───────────────────────────
SWARM_ENABLED=true
SWARM_TIMEOUT_SECONDS=30
